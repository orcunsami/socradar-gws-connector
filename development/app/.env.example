# SOCRadar Google Workspace Connector — app config
# Copy to .env and fill. NEVER commit .env. All values below are placeholders.

# --- Web / session ---
SECRET_KEY=change-me-to-a-long-random-string
# Local-only escape hatch to skip Google OAuth while developing (NEVER true in prod):
DEV_LOGIN=false
# "dev" honors DEV_LOGIN off Cloud Run; set "prod" for any real deployment.
APP_ENV=dev

# --- Google OAuth (admin sign-in) ---
# Create an OAuth client (Web application) in the Google Cloud console for the
# Internal-user-type consent screen. Redirect URI for local: http://localhost:8080/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Internal restriction: only users of this Workspace org may sign in (hd claim check).
ALLOWED_DOMAIN=your-domain.com

# --- Connector identity (keyless domain-wide delegation) ---
# Local fallback only; resolved from PATH on Cloud Run (ambient metadata token is used there).
GCLOUD_PATH=gcloud
# The DWD-authorized runtime service account (set at deploy).
SERVICE_ACCOUNT=gws-connector@your-gcp-project.iam.gserviceaccount.com
# Impersonation subject; ALSO excluded from remediation (never sign out the operator).
ADMIN_SUBJECT=admin@your-domain.com
# On Cloud Run leave BOOTSTRAP_TOKEN unset (ambient metadata token is used).
# Locally the app shells out to gcloud; or paste a token here to override:
# BOOTSTRAP_TOKEN=

# --- Default tenant (single-tenant bootstrap; the tenant table is still used) ---
# Google's generic alias "my_customer", or the immutable customerId from the Admin SDK.
DEFAULT_CUSTOMER_ID=my_customer
DEFAULT_DOMAIN=your-domain.com

# --- SOCRadar feed (seed for the default tenant; editable in Settings) ---
FEED_BASE=https://platform.socradar.com
FEED_COMPANY_ID=
FEED_API_KEY=
FEED_START_DATE=2026-06-01

# --- Storage ---
# "sqlite" (local, ephemeral on Cloud Run /tmp) | "firestore" (durable on Cloud Run)
STORAGE_BACKEND=sqlite
DB_PATH=app_data.sqlite3
# PROJECT_ID=                      # GCP project for firestore/bigquery; empty = ADC default

# ==========================================================================
# Everything below is optional. Defaults are the safe production posture.
# Uncomment to override. The deploy script sets the production values for you.
# ==========================================================================

# --- Production guard ---
# APP_ENV is set to prod by the deploy script; it makes the DEV_LOGIN bypass impossible on Cloud Run.
# SESSION_MAX_AGE=28800            # session cookie lifetime in seconds (default 8h)

# --- RBAC: who may run destructive remediation (CSV of emails; empty = only ADMIN_SUBJECT) ---
# REMEDIATION_ADMINS=admin@your-domain.com,soc@your-domain.com

# --- Remediation automation (default = the safe manual posture) ---
# REMEDIATION_MODE=manual          # manual | semi_auto | auto
# AUTO_ENABLED_ACTIONS=            # CSV allow-list auto/semi may apply (suspend is never auto)
# AUTO_DRY_RUN=true                # auto mode logs intended actions without executing them
# AUTO_KILL_SWITCH=false           # true halts all autonomous actions immediately
# AUTO_HIGH_BLAST_ACTIONS=suspend  # actions that never auto-fire (always need a human)
# AUTO_MAX_USERS_PER_SCAN=5        # blast-radius cap per scan per tenant
# AUTO_EXCLUDE_USERS=              # CSV VIP/break-glass emails never auto-actioned
# AUTO_RATE_LIMIT_PER_HOUR=20      # circuit breaker: max auto actions per hour per tenant (0 = off)
# ANOMALY_SPIKE_FACTOR=3.0         # found_count above factor x median(baseline) suppresses auto (0 = off)
# ANOMALY_MIN_COUNT=5              # ignore spikes below this absolute count
# ANOMALY_BASELINE_SCANS=5         # rolling window of prior scans for the baseline

# --- Two-person (four-eyes) approval for high-blast actions ---
# REQUIRE_APPROVAL=false           # true = high-blast actions need a second admin to approve
# APPROVAL_ACTIONS=suspend,reset_password,disable_2sv

# --- Feed window + paging ---
# FEED_LOOKBACK_DAYS=0             # above 0 = scan from (today minus N days); 0 = use FEED_START_DATE
# FEED_PAGE_LIMIT=100              # records per feed page
# FEED_MAX_PAGES=50                # cap per source per scan (the scan reports truncated if hit)

# --- Close the loop: resolve the SOCRadar alarm after a successful remediation ---
# CLOSE_SOCRADAR_ALARM=false

# --- Scheduled (headless) scan trigger token (Cloud Scheduler sends it as X-Scan-Token) ---
# SCAN_TRIGGER_TOKEN=

# --- At-rest protection (injected from Secret Manager on Cloud Run) ---
# AUDIT_HMAC_KEY=                  # off-box HMAC key for the tamper-evident audit hash chain
# FERNET_KEY=                      # Fernet key to encrypt stored feed keys at rest

# --- Analytics export (optional) ---
# ANALYTICS_BIGQUERY=false
# BIGQUERY_DATASET=socradar
# BIGQUERY_LOCATION=US             # set to your deploy REGION for data residency
