# ============================================================================
#  SOCRadar Google Workspace Connector — config
# ============================================================================
#  EASIEST WAY:  run   bash helper/create-env.sh
#    It auto-detects your project / domain / region / billing, writes deploy/customer.env
#    for you, and leaves only the SOCRadar feed key + company id for you to paste.
#
#  BY HAND (if you prefer):
#   1. If THIS file is named customer.env.example -> run  bash deploy/setup.sh  first.
#      It copies this template to deploy/customer.env and opens THAT for you to edit.
#   2. Fill the values in deploy/customer.env, SAVE, then run  bash deploy/setup.sh  to deploy.
#   (To see your projects/billing first:  bash helper/run_all_validations.sh)
#  customer.env is gitignored — your secrets never commit. Everything runs in YOUR
#  Google Cloud project. SOCRadar hosts nothing.
# ----------------------------------------------------------------------------

# --- 1) Your Google Cloud project ---
PROJECT=customer-gcp-project            # <-- your GCP project id
REGION=europe-west1                     # Cloud Run region (leave as-is if unsure)

# --- 2) Your Google Workspace ---
DOMAIN=customer.com                     # <-- your verified Workspace domain
# The admin the connector IMPERSONATES on every call. Use a DEDICATED least-privilege custom-role admin
# (e.g. connector-bot@), NOT a super-admin (see the 7-privilege role in docs/deploy-to-gcp-guide.md).
ADMIN_SUBJECT=connector-bot@customer.com   # <-- least-privilege admin to impersonate
CUSTOMER_ID=my_customer                 # leave as-is, or your immutable Google customerId

# --- 3) Your SOCRadar feed ---
FEED_API_KEY=                           # <-- paste your SOCRadar feed API key (this file is gitignored)
FEED_COMPANY_ID=your-company-id         # <-- your SOCRadar company id
FEED_BASE=https://platform.socradar.com # SOCRadar platform API base (leave as-is)

# --- 4) Admin UI sign-in (Google OAuth Web client; create one in the Cloud console) ---
# REQUIRED for the SERVICE (DEPLOY_MODE=service|both): without a sign-in method the admin-UI container
# fail-closes on Cloud Run and will NOT start. Create a Web OAuth client (Internal consent screen) with
# redirect URI http://localhost:8080/auth/callback and paste the id+secret here.
# You may leave these empty ONLY for a headless DEPLOY_MODE=job deploy (no UI).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- 5) What to deploy ---
#   service = the admin UI + scheduled scans (default)
#   job     = the large-feed backfill Cloud Run Job (no request timeout) — uses Firestore
#   both    = the Service, then the Job (full production setup)
DEPLOY_MODE=service
STORAGE_BACKEND=sqlite                  # sqlite (single instance) or firestore (durable, multi-instance/Job)

# --- 6) Advanced (optional) ---
# Reuse an existing already-DWD-authorized service account (skips SA create + the admin.google.com step):
# SA_EMAIL=connector@your-project.iam.gserviceaccount.com
# Authorize more remediation admins (comma-separated); empty = ADMIN_SUBJECT only:
# REMEDIATION_ADMINS=secops1@customer.com,secops2@customer.com
# Use a file for the feed key instead of pasting it above:
# FEED_KEY_FILE=/absolute/path/to/feed-key.txt
