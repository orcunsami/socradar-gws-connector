# Deploy-to-GCP config — copy to customer.env and fill. customer.env is gitignored (never commits).
# On camera, run ONE clean line instead of a long env block:
#   set -a; source deploy/customer.env; set +a
#   bash deploy/deploy-to-gcp.sh

# The customer's GCP project id + Cloud Run region
PROJECT=customer-gcp-project
REGION=europe-west1

# The customer's Workspace
ADMIN_SUBJECT=admin@customer.com        # a real super-admin to impersonate (also remediation-excluded)
DOMAIN=customer.com                     # the verified Workspace domain
CUSTOMER_ID=my_customer                 # Google's generic alias, or the immutable customerId

# SOCRadar feed
FEED_KEY_FILE=/absolute/path/to/feed-key.txt   # a file containing ONLY the feed API key (keep it outside the repo)
FEED_BASE=https://platform.socradar.com
FEED_COMPANY_ID=your-company-id

# OAuth Web client for the admin UI sign-in (created in the Cloud console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: reuse an existing already-DWD-authorized service account (skips SA create + the admin.google.com
# step). Leave empty for the authentic from-scratch flow (the script creates a fresh SA and prints the
# client id + scopes for you to authorize).
# SA_EMAIL=
