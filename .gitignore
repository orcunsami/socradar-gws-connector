# Secrets / credentials — never commit
.env
*.env
service-account*.json
*.creds
*.key

# Local-only files with passwords / API keys
*.local.*
development/poc/test-users.local.md

# PoC scratch — local-only working notes (not product code)
development/poc/

# API reference dir — local-only, excluded from the package
api-reference/

