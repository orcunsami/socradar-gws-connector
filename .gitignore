sonuc1.txt
sonuc2.txt
arastirma4.txt
RESEARCH-BRIEF.md
HANDOFF-AUTO.md
**/HANDOFF-AUTO.md
HANDOFF.md
progress/handoff.md

# Terraform state/vars carry secrets in plaintext
*.tfvars
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# App local state / venv (generic patterns — sqlite sidecars carry the same plaintext key)
.venv/
development/app/.venv/
*.sqlite3
*.sqlite3-journal
*.sqlite3-wal
*.sqlite3-shm

# Personal recording aid (Turkish, video-shoot specific) — not product
kurulum-takip.html

